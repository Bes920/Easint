# OSINT Platform Configuration
# Copy this file to .env and fill in your actual API keys
# .env is in .gitignore and won't be committed to GitHub

# VirusTotal API Key
# Get it from: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=YOUR_API_KEY_HERE

# AbuseIPDB API Key  
# Get it from: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=YOUR_API_KEY_HERE

# Have I Been Pwned API Key
# Get it from: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=YOUR_API_KEY_HERE

# Shodan API Key (optional)
# Get it from: https://account.shodan.io/
SHODAN_API_KEY=YOUR_API_KEY_HERE

# Hunter.io API Key (optional)
# Get it from: https://hunter.io/
HUNTER_API_KEY=YOUR_API_KEY_HERE

# Blockchain API Key (optional)
# Get it from: https://www.blockchain.com/api
BLOCKCHAIN_API_KEY=YOUR_API_KEY_HERE
